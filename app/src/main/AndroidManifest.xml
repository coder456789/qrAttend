<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Precise location needed for geofencing while scanning -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Camera needed for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Background location is NOT needed as attendance is only marked in foreground -->

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QrAttend">

        <!-- Splash Screen (LAUNCHER) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.QrAttend.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity android:name=".ui.LoginActivity"
            android:exported="false" />
        <activity android:name=".ui.SignupActivity"
            android:exported="false" />

        <!-- Student -->
        <activity android:name=".ui.StudentDashboardActivity"
            android:exported="false" />
        <activity android:name=".ui.AttendanceHistoryActivity"
            android:exported="false" />
        <activity android:name=".ui.ScanQRActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Teacher -->
        <activity android:name=".ui.TeacherDashboardActivity"
            android:exported="false" />
        <activity android:name=".ui.StartSessionActivity"
            android:exported="false" />
        <activity android:name=".ui.DisplayQRActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:keepScreenOn="true" />
        <activity android:name=".ui.SessionAttendanceActivity"
            android:exported="false" />



        <!-- Shared -->
        <activity android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- Keep original MainActivity as fallback -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Firebase Cloud Messaging service for push notifications -->
        <service
            android:name=".firebase.FCMService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>