<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/qrDisplayBackground"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@android:color/transparent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:title="@string/display_qr_title"
        app:titleTextColor="@color/white" />

    <!-- ── QR Code Display Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/ivQRCode"
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:contentDescription="@string/display_qr_title"
            android:padding="16dp"
            android:scaleType="fitCenter" />
    </com.google.android.material.card.MaterialCardView>

    <!-- ── Countdown Timer ── -->
    <TextView
        android:id="@+id/tvCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="sans-serif-medium"
        android:textColor="#B3FFFFFF"
        android:textSize="15sp" />

    <!-- ── Live Attendance Count Card ── -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        app:cardBackgroundColor="#1A2744"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="40dp"
            android:paddingVertical="20dp">

            <TextView
                android:id="@+id/tvLiveCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="0"
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.08"
                android:text="@string/live_count"
                android:textAllCaps="true"
                android:textColor="#80FFFFFF"
                android:textSize="11sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- ── End Session Button ── -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEndSession"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:text="@string/end_session"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:backgroundTint="@color/error"
        app:cornerRadius="26dp" />

</LinearLayout>
