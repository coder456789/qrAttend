<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Base.Theme.QrAttend" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primaryDark</item>
        <item name="colorPrimaryVariant">@color/primaryDark</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@color/primaryDark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/textPrimary</item>
        <item name="android:textColorSecondary">@color/textSecondary</item>
    </style>

    <style name="Theme.QrAttend" parent="Base.Theme.QrAttend" />

    <!-- NoActionBar variant (used by all activities with custom Toolbar) -->
    <style name="Theme.QrAttend.NoActionBar" parent="Theme.QrAttend">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <!-- Splash theme (full-screen, no action bar, gradient background) -->
    <style name="Theme.QrAttend.Splash" parent="Theme.QrAttend.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_gradient_splash</item>
        <item name="android:statusBarColor">@color/splashStart</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

</resources>