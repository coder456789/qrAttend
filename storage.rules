rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
// QR-Attend — Firebase Storage Security Rules
// ═══════════════════════════════════════════════════════════════════════
//
// Paths:
//   leaveProofs/{studentId}/{fileName}  → Leave application attachments
//
// ═══════════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── Leave Proof Uploads ──────────────────────────────────────────────
    //
    // Students can upload their own proof files.
    // Teachers and admins can read all proof files.
    // File size limited to 10 MB.
    //
    match /leaveProofs/{studentId}/{fileName} {

      // Students can write only to their own folder
      allow write: if request.auth != null
                   && request.auth.uid == studentId
                   && request.resource.size <= 10 * 1024 * 1024   // 10 MB max
                   && (request.resource.contentType.matches('image/.*')
                       || request.resource.contentType == 'application/pdf');

      // The student themselves can read their own files; teachers/admins can read all
      allow read: if request.auth != null;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
